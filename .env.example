DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/om_restaurant?sslmode=require"

# Payment provider
USE_TOAST="false"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Checkmate -> Toast printing
CHECKMATE_ENABLED="false"
CHECKMATE_API_BASE_URL="https://sandbox-api.itsacheckmate.com"
CHECKMATE_CLIENT_ID=""
CHECKMATE_CLIENT_SECRET=""
CHECKMATE_ACCESS_TOKEN=""
CHECKMATE_ACCESS_TOKEN_EXPIRES_AT=""
CHECKMATE_REFRESH_TOKEN=""
CHECKMATE_ORDER_SOURCE=""
CHECKMATE_LOCATION_ID=""
CHECKMATE_LOCATION_NAME="Om Indian Restaurant"
CHECKMATE_TIMEZONE="America/New_York"
CHECKMATE_MENU_ITEM_MAP_JSON="{}"

# Toast custom integration
TOAST_API_URL=""
TOAST_CLIENT_ID=""
TOAST_CLIENT_SECRET=""
TOAST_RESTAURANT_GUID=""
TOAST_MERCHANT_GUID=""
TOAST_RSA_PUBLIC_KEY=""
TOAST_KEY_ID=""
TOAST_PICKUP_DINING_OPTION_GUID=""
TOAST_DELIVERY_DINING_OPTION_GUID=""
