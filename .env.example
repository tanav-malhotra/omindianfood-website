DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/om_restaurant?sslmode=require"

# Payment provider
USE_TOAST="false"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Toast custom integration
TOAST_API_URL=""
TOAST_CLIENT_ID=""
TOAST_CLIENT_SECRET=""
TOAST_RESTAURANT_GUID=""
TOAST_MERCHANT_GUID=""
TOAST_RSA_PUBLIC_KEY=""
TOAST_KEY_ID=""
TOAST_PICKUP_DINING_OPTION_GUID=""
TOAST_DELIVERY_DINING_OPTION_GUID=""
TOAST_ITEM_GUIDS_JSON="{}"

# Public site URL
NEXT_PUBLIC_SITE_URL="https://www.your-domain.com"

# Admin auth
ADMIN_EMAIL="restaurant@example.com"
ADMIN_PASSWORD_HASH="scrypt$replace-with-output-from-npm-run-hash-admin-password$hash"
AUTH_SECRET="replace-with-a-long-random-secret"

# Business settings
NEXT_PUBLIC_TIMEZONE="America/New_York"
